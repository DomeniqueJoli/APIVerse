generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Usuario {
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  dataNasc DateTime
  perfilGit String
  perfilLinkedin String
  linkPortfolio String
  senha String
  biografia String
  createdAt DateTime @default(now())
}